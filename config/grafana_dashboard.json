{
  "dashboard": {
    "title": "GEO Promotion Backend 监控仪表板",
    "description": "GEO优化系统性能监控和业务指标",
    "tags": ["geo", "promotion", "monitoring", "ai"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "title": "系统健康状态",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"geo-promotion-backend\"}",
            "legendFormat": "应用状态"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "mappings": [],
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "title": "API请求速率",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"geo-promotion-backend\"}[5m])",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 6,
          "y": 0
        }
      },
      {
        "title": "API响应时间",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"geo-promotion-backend\"}[5m]))",
            "legendFormat": "P95响应时间"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"geo-promotion-backend\"}[5m]))",
            "legendFormat": "P50响应时间"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "title": "内容优化统计",
        "type": "stat",
        "targets": [
          {
            "expr": "geo_optimizations_total{job=\"geo-promotion-backend\"}",
            "legendFormat": "总优化次数"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 12
        }
      },
      {
        "title": "平均置信度分数",
        "type": "gauge",
        "targets": [
          {
            "expr": "avg(geo_optimization_confidence{job=\"geo-promotion-backend\"})",
            "legendFormat": "平均置信度"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.5
                },
                {
                  "color": "green",
                  "value": 0.8
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 6,
          "y": 12
        }
      },
      {
        "title": "平台分发成功率",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(geo_distribution_success{job=\"geo-promotion-backend\"}) by (platform)",
            "legendFormat": "{{platform}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      },
      {
        "title": "AI引用监控",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(geo_citation_count{job=\"geo-promotion-backend\"}) by (platform)",
            "legendFormat": "{{platform}}引用数"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        }
      },
      {
        "title": "数据库连接状态",
        "type": "stat",
        "targets": [
          {
            "expr": "pg_up{job=\"postgres\"}",
            "legendFormat": "PostgreSQL状态"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "title": "Redis内存使用",
        "type": "gauge",
        "targets": [
          {
            "expr": "redis_memory_used_bytes{job=\"redis\"} / redis_memory_max_bytes{job=\"redis\"}",
            "legendFormat": "内存使用率"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.7
                },
                {
                  "color": "red",
                  "value": 0.9
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "title": "系统资源使用",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_cpu_seconds_total{job=\"node-exporter\", mode!=\"idle\"}[5m])",
            "legendFormat": "CPU使用率"
          },
          {
            "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}",
            "legendFormat": "内存可用率"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  },
  "overwrite": true,
  "message": "GEO Promotion Backend监控仪表板"
}